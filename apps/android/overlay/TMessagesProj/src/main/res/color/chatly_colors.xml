    <color name="chatly_accent_dark">#0D9488</color>       <!-- Teal 600 - Dark accent -->
    
    <!-- Gradient Colors for Premium UI -->
    <color name="chatly_gradient_start">#6366F1</color>    <!-- Indigo -->
    <color name="chatly_gradient_mid">#8B5CF6</color>      <!-- Violet -->
    <color name="chatly_gradient_end">#EC4899</color>      <!-- Pink -->
    
    <!-- Background Colors -->
    <color name="chatly_background">#0F172A</color>        <!-- Slate 900 - Dark bg -->
