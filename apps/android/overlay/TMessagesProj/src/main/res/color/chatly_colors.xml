    <color name="chatly_primary">#6366F1</color>           <!-- Indigo 500 - Main brand color -->
    <color name="chatly_primary_dark">#4F46E5</color>      <!-- Indigo 600 - Darker variant -->
    <color name="chatly_primary_light">#818CF8</color>     <!-- Indigo 400 - Lighter variant -->
